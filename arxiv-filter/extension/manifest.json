{
  "manifest_version": 3,
  "name": "Alpha",
  "version": "1.0",
  "description": "Save any webpage to your Alpha reading list.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/yurr.png",
      "48": "icons/yurr.png",
      "128": "icons/yurr.png"
    }
  },
  "icons": {
    "16": "icons/yurr.png",
    "48": "icons/yurr.png",
    "128": "icons/yurr.png"
  }
}
