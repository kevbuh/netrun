# NetRun environment configuration
# Copy to .env and edit as needed. Values here are defaults.

# Google OAuth Client ID (override with your own Google Cloud project)
# GOOGLE_CLIENT_ID=856091829253-1n5fu44j867fu88larg1vvnqds4pmkh4.apps.googleusercontent.com

# Ollama API host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Enable SSL certificate verification for outbound requests (default: disabled)
# NETRUN_VERIFY_SSL=1
